 void RpgStrategy::OnStrategyAdded(BotState state)
 {
-    ai->ChangeStrategy("+rpg quest,+rpg vendor,+rpg explore,+rpg maintenance,+rpg player,+rpg bg,+rpg guild,+rpg bank", state);
+    // Only add sub-strategies that aren't already in the engine.
+    // This prevents OnStrategyAdded from blindly re-adding sub-strategies
+    // the user explicitly removed with -rpg <sub>.
+    std::vector<std::string> subs = {
+        "rpg quest", "rpg vendor", "rpg explore", "rpg maintenance",
+        "rpg player", "rpg bg", "rpg guild", "rpg bank"
+    };
+
+    std::string toAdd;
+    for (const auto& sub : subs)
+    {
+        if (!ai->HasStrategy(sub, state))
+        {
+            if (!toAdd.empty()) toAdd += ",";
+            toAdd += "+" + sub;
+        }
+    }
+
+    if (!toAdd.empty())
+        ai->ChangeStrategy(toAdd, state);
 }
